{
  "name": "pr-bot",
  "version": "2.0.0",
  "description": "Slack PR notifier that posts and updates PR messages in real-time",
  "type": "commonjs",
  "main": "entrypoint/http/index.js",
  "_moduleAliases": {
    "@app": "./src",
    "@config": "./config/index.js",
    "@service": "./src/service",
    "@clients": "./src/clients",
    "@database": "./src/database",
    "@helper": "./src/helper",
    "@constants": "./src/constants"
  },
  "engines": {
    "node": "^22"
  },
  "scripts": {
    "start": "node entrypoint/http/index.js",
    "dev": "node entrypoint/http/index.js",
    "test-manual": "node test/manual/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "github",
    "slack",
    "pr",
    "notifications"
  ],
  "author": "SWORDHealth",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "@slack/bolt": "^3.17.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.3.1",
    "module-alias": "^2.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0"
  }
}
